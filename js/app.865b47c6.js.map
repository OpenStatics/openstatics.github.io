<template>
  <div class="container-fluid">
    <div class="row my-2 justify-content-center">
      <div id="boxLeft" class="my-2" style="width:520px; height:700px;"></div>
      <div id="boxRight" class="my-2" style="width:620px; height:620px;"></div>
    </div>
  </div>
</template>

<script>
import inertiaTypesImg from "../../../assets/inertia_types.png";

export default {
  data() {
    return {
      bL: null,
      bR: null,
      sliders: {},
      coordButtons: {},
      sectionButtons: {},
      centroidButtons: {},
      inertiaButtons: {},
      rightObjects: null,
      values: {
        coordVisible: "off",
        section: "1",
        centroid: "on",
        inertia: "on"
      }
    };
  },
  mounted() {
    this.initBoards();
  },
  beforeDestroy() {
    if (this.bL) JXG.JSXGraph.freeBoard(this.bL);
    if (this.bR) JXG.JSXGraph.freeBoard(this.bR);
  },
  methods: {
    fmtNum(n, digits = 3) {
      return Number(n)
        .toFixed(digits)
        .replace(/\.0+$/, "")
        .replace(/(\.\d*?)0+$/, "$1");
    },
    getSectionMetrics() {
      const sliderValue = key => (this.sliders[key] ? Number(this.sliders[key].Value()) : 0);

      const L = Math.max(0.1, sliderValue("length"));
      const H = Math.max(0.1, sliderValue("height"));
      const tRaw = Math.max(0.01, sliderValue("thickness"));
      const t = Math.min(tRaw, 0.95 * Math.min(L, H));

      const yBase = -0.5;
      const A1 = L * t;
      const A2 = t * (H - t);
      const A = A1 + A2;

      const y1 = t / 2;
      const y2 = t + (H - t) / 2;
      const ybarLocal = A > 0 ? (A1 * y1 + A2 * y2) / A : 0;

      const xbar = 0;
      const ybar = yBase + ybarLocal;

      const Ix1c = (L * Math.pow(t, 3)) / 12;
      const Ix2c = (t * Math.pow(H - t, 3)) / 12;
      const Iy1c = (t * Math.pow(L, 3)) / 12;
      const Iy2c = ((H - t) * Math.pow(t, 3)) / 12;

      const d1 = Math.abs(y1 - ybarLocal);
      const d2 = Math.abs(y2 - ybarLocal);
      const Ixc = Ix1c + A1 * d1 * d1 + Ix2c + A2 * d2 * d2;
      const Iyc = Iy1c + Iy2c;

      const dx = sliderValue("newX");
      const dy = sliderValue("newY");

      const Ix = Ixc + A * ybar * ybar;
      const Iy = Iyc + A * xbar * xbar;
      const xbarPrime = xbar - dx;
      const ybarPrime = ybar - dy;
      const IxPrime = Ixc + A * ybarPrime * ybarPrime;
      const IyPrime = Iyc + A * xbarPrime * xbarPrime;
      const IxyPrime = A * xbarPrime * ybarPrime;

      return {
        xbar,
        ybar,
        xbarPrime,
        ybarPrime,
        Ix,
        Iy,
        IxPrime,
        IyPrime,
        IxyPrime
      };
    },
    setBtnActive(btn, active) {
      if (!btn || !btn.rendNodeButton) return;
      btn.rendNodeButton.classList.toggle("btn-primary", !active);
      btn.rendNodeButton.classList.toggle("btn-warning", active);
    },
    updateToggleStyles() {
      Object.keys(this.coordButtons).forEach(key => {
        this.setBtnActive(this.coordButtons[key], key === this.values.coordVisible);
      });

      Object.keys(this.sectionButtons).forEach(key => {
        this.setBtnActive(this.sectionButtons[key], key === this.values.section);
      });

      Object.keys(this.centroidButtons).forEach(key => {
        this.setBtnActive(this.centroidButtons[key], key === this.values.centroid);
      });

      Object.keys(this.inertiaButtons).forEach(key => {
        this.setBtnActive(this.inertiaButtons[key], key === this.values.inertia);
      });
    },
    initBoards() {
      const bL = JXG.JSXGraph.initBoard("boxLeft", {
        boundingbox: [-15, 10, 15, -27.8],
        keepAspectRatio: false,
        showCopyright: false,
        showNavigation: false,
        showZoom: false,
        pan: { enabled: false },
        zoom: { wheel: false },
        axis: false
      });
      bL.resizeContainer(520, 700);

      const bR = JXG.JSXGraph.initBoard("boxRight", {
        boundingbox: [-1.05, 1.05, 1.05, -1.05],
        keepAspectRatio: false,
        showCopyright: false,
        showNavigation: false,
        showZoom: false,
        pan: { enabled: false },
        zoom: { wheel: false },
        axis: false
      });
      bR.resizeContainer(1160, 620);

      bR.resizeContainer(620, 620);
      this.bL = bL;
      this.bR = bR;
      this.drawLeftControls();
      this.drawModel();
      bL.fullUpdate();
      bR.fullUpdate();
    },
    addToggleButton(group, key, x, y, label, onClick) {
      const btn = this.bL.create("button", [x, y, label, onClick], { fixed: true });
      btn.rendNodeButton.classList.add("btn", "btn-primary", "btn-sm");
      group[key] = btn;
      return btn;
    },
    drawLeftControls() {
      const bL = this.bL;
      const sliders = {};
      this.sliders = sliders;

      bL.create("text", [-13.4, 9.0, "Coordinates visibility"], { fontSize: 16, fixed: true });
      this.addToggleButton(this.coordButtons, "on", -2.8, 9.0, "On", () => {
        this.values.coordVisible = "on";
        this.updateToggleStyles();
      });
      this.addToggleButton(this.coordButtons, "off", -0.8, 9.0, "Off", () => {
        this.values.coordVisible = "off";
        this.updateToggleStyles();
      });

      bL.create("text", [-13.4, 7.2, "Select section type"], {
        fontSize: 24,
        fixed: true,
        cssStyle: "font-weight:700"
      });

      bL.create("image", [inertiaTypesImg, [-12.6, -0.8], [20.0, 7.4]], {
        fixed: true,
        highlight: false
      });

      bL.create("text", [-12.9, -3.8, "Section:"], { fontSize: 16, fixed: true });
      const sectionRadioX = [-9.8, -8.0, -6.2, -4.4, -2.6, -0.8, 1.0, 2.8];
      sectionRadioX.forEach((x, idx) => {
        const key = String(idx + 1);
        this.addToggleButton(this.sectionButtons, key, x, -3.8, key, () => {
          this.values.section = key;
          this.updateToggleStyles();
          this.refreshBoards();
        });
      });

      const sliderDefs = [
        { key: "length", label: "Length [m]", y: -6.8, min: 0.1, val: 1.0, max: 5.0 },
        { key: "height", label: "Height [m]", y: -9.4, min: 0.1, val: 1.0, max: 5.0 },
        { key: "thickness", label: "Thickness [m]", y: -12.0, min: 0.05, val: 0.2, max: 2.0 },
        { key: "newX", label: "New x axis [m]", y: -14.6, min: -2.0, val: 0.0, max: 2.0 },
        { key: "newY", label: "New y axis [m]", y: -17.2, min: -2.0, val: 0.0, max: 2.0 }
      ];

      sliderDefs.forEach(def => {
        bL.create("text", [-13.4, def.y, def.label], { fontSize: 16, fixed: true });
        sliders[def.key] = bL.create("slider", [[-4.6, def.y], [2.7, def.y], [def.min, def.val, def.max]], {
          name: "",
          withLabel: false,
          showInfobox: false,
          snapWidth: 0.01,
          fixed: false,
          strokeColor: "#1f77b4",
          fillColor: "#1f77b4"
        });
        bL.create("text", [3.9, def.y, () => Number(sliders[def.key].Value()).toFixed(2).replace(/\.00$/, "")], {
          fontSize: 16,
          fixed: true
        });
      });

      bL.create("text", [-13.4, -19.6, "Position of Centroid"], { fontSize: 16, fixed: true });
      this.addToggleButton(this.centroidButtons, "on", -3.8, -19.6, "On", () => {
        this.values.centroid = "on";
        this.updateToggleStyles();
      });
      this.addToggleButton(this.centroidButtons, "off", -1.8, -19.6, "Off", () => {
        this.values.centroid = "off";
        this.updateToggleStyles();
      });

      bL.create("text", [
        -13.4,
        -21.2,
        () => {
          const m = this.getSectionMetrics();
          return `xbar = ${this.fmtNum(m.xbar)} m     ybar = ${this.fmtNum(m.ybar)} m`;
        }
      ], { fontSize: 16, fixed: true });
      bL.create("text", [
        -13.4,
        -22.3,
        () => {
          const m = this.getSectionMetrics();
          return `x'bar = ${this.fmtNum(m.xbarPrime)} m     y'bar = ${this.fmtNum(m.ybarPrime)} m`;
        }
      ], { fontSize: 16, fixed: true });

      bL.create("text", [-13.4, -24.0, "Moment of Inertia"], { fontSize: 16, fixed: true });
      this.addToggleButton(this.inertiaButtons, "on", -3.8, -24.0, "On", () => {
        this.values.inertia = "on";
        this.updateToggleStyles();
      });
      this.addToggleButton(this.inertiaButtons, "off", -1.8, -24.0, "Off", () => {
        this.values.inertia = "off";
        this.updateToggleStyles();
      });

      bL.create("text", [
        -13.4,
        -25.2,
        () => {
          const m = this.getSectionMetrics();
          return `Ix = ${this.fmtNum(m.Ix)} m^4    Iy = ${this.fmtNum(m.Iy)} m^4`;
        }
      ], { fontSize: 15, fixed: true });
      bL.create("text", [
        -13.4,
        -26.4,
        () => {
          const m = this.getSectionMetrics();
          return `Ix' = ${this.fmtNum(m.IxPrime)} m^4   Iy' = ${this.fmtNum(m.IyPrime)} m^4   Ixy = ${this.fmtNum(m.IxyPrime)} m^4`;
        }
      ], { fontSize: 15, fixed: true });

      Object.keys(sliders).forEach(key => {
        sliders[key].on("drag", () => this.refreshBoards());
      });

      this.updateToggleStyles();
    },
    refreshBoards() {
      if (!this.bL || !this.bR) return;
      this.bL.fullUpdate();
      this.bR.fullUpdate();
    },
    drawModel() {
      if (!this.bR) return;
      if (this.rightObjects) return;

      const bR = this.bR;
      const sliderValue = key => (this.sliders[key] ? Number(this.sliders[key].Value()) : 0);
      const axisScale = 0.22;
      const axisBaseX = -0.83;
      const axisBaseY = 0.48;
      const axisLenX = 0.26;
      const axisLenY = 0.26;

      const shapeScale = () => {
        const L = Math.max(0.1, sliderValue("length"));
        const H = Math.max(0.1, sliderValue("height"));
        return 0.85 / Math.max(L, H);
      };
      const Ld = () => sliderValue("length") * shapeScale();
      const Hd = () => sliderValue("height") * shapeScale();
      const Td = () => {
        const tRaw = sliderValue("thickness") * shapeScale();
        const maxT = Math.min(Ld(), Hd()) * 0.95;
        return Math.max(0.02, Math.min(tRaw, maxT));
      };

      const xC = 0;
      const yBase = -0.5;
      const xL = () => xC - Ld() / 2;
      const xR = () => xC + Ld() / 2;
      const yTop = () => yBase + Hd();
      const yMid = () => (yBase + yTop()) / 2;
      const xWebL = () => xC - Td() / 2;
      const xWebR = () => xC + Td() / 2;
      const yTopInset = () => yTop() - Td();
      const yBotInset = () => yBase + Td();

      const sectionPoints = () => {
        const s = this.values.section;
        const t = Td();
        const xl = xL();
        const xr = xR();
        const yb = yBase;
        const yt = yTop();
        const ym = yMid();
        const ymTop = ym + t / 2;
        const ymBot = ym - t / 2;
        const xlt = xl + t;
        const xrt = xr - t;
        const xwl = xWebL();
        const xwr = xWebR();

        if (s === "2") {
          return [
            [xl, yt],
            [xlt, yt],
            [xlt, ymTop],
            [xrt, ymTop],
            [xrt, ym],
            [xr, ym],
            [xr, yb],
            [xrt, yb],
            [xrt, ymBot],
            [xlt, ymBot],
            [xlt, ym],
            [xl, ym]
          ];
        }

        if (s === "3") {
          return [
            [xl, ymTop],
            [xwl, ymTop],
            [xwl, yt],
            [xwr, yt],
            [xwr, ymTop],
            [xr, ymTop],
            [xr, ymBot],
            [xwr, ymBot],
            [xwr, yb],
            [xwl, yb],
            [xwl, ymBot],
            [xl, ymBot]
          ];
        }

        if (s === "4") {
          return [
            [xl, yt],
            [xr, yt],
            [xr, yTopInset()],
            [xwr, yTopInset()],
            [xwr, yBotInset()],
            [xr, yBotInset()],
            [xr, yb],
            [xl, yb],
            [xl, yBotInset()],
            [xwl, yBotInset()],
            [xwl, yTopInset()],
            [xl, yTopInset()]
          ];
        }

        if (s === "5") {
          return [
            [xl, yt],
            [xr, yt],
            [xr, yt - t],
            [xlt, yt - t],
            [xlt, yb + t],
            [xr, yb + t],
            [xr, yb],
            [xl, yb],
            [xl, yb],
            [xl, yb],
            [xl, yb],
            [xl, yb]
          ];
        }

        if (s === "6" || s === "7") {
          return [
            [xl, yt],
            [xr, yt],
            [xr, yb],
            [xl, yb],
            [xl, yb],
            [xl, yb],
            [xl, yb],
            [xl, yb],
            [xl, yb],
            [xl, yb],
            [xl, yb],
            [xl, yb]
          ];
        }

        if (s === "8") {
          return [
            [xC, yb],
            [xC, yb],
            [xC, yb],
            [xC, yb],
            [xC, yb],
            [xC, yb],
            [xC, yb],
            [xC, yb],
            [xC, yb],
            [xC, yb],
            [xC, yb],
            [xC, yb]
          ];
        }

        return [
          [xl, yb],
          [xr, yb],
          [xr, yb + t],
          [xwr, yb + t],
          [xwr, yt],
          [xwl, yt],
          [xwl, yb + t],
          [xl, yb + t],
          [xl, yb + t],
          [xl, yb + t],
          [xl, yb + t],
          [xl, yb + t]
        ];
      };

      const p = Array.from({ length: 12 }, (_, idx) => {
        return bR.create("point", [() => sectionPoints()[idx][0], () => sectionPoints()[idx][1]], {
          visible: false,
          fixed: true,
          highlight: false
        });
      });

      const section = bR.create("polygon", p, {
        fillColor: "#7878df",
        fillOpacity: 0.95,
        withLines: true,
        borders: {
          strokeColor: "#7878df",
          strokeWidth: 2,
          fixed: true,
          highlight: false
        },
        vertices: { visible: false },
        fixed: true,
        highlight: false,
        visible: () => this.values.section !== "8"
      });

      const bgColor = "#efefef";
      const cX = () => xC;
      const cY = () => yBase + Hd() / 2;

      const voidR1 = bR.create("point", [() => xL() + Td(), () => yBase + Td()], { visible: false, fixed: true, highlight: false });
      const voidR2 = bR.create("point", [() => xR() - Td(), () => yBase + Td()], { visible: false, fixed: true, highlight: false });
      const voidR3 = bR.create("point", [() => xR() - Td(), () => yTop() - Td()], { visible: false, fixed: true, highlight: false });
      const voidR4 = bR.create("point", [() => xL() + Td(), () => yTop() - Td()], { visible: false, fixed: true, highlight: false });

      const rectVoid = bR.create("polygon", [voidR1, voidR2, voidR3, voidR4], {
        fillColor: bgColor,
        fillOpacity: 1,
        withLines: true,
        borders: {
          strokeColor: bgColor,
          strokeWidth: 2,
          fixed: true,
          highlight: false
        },
        vertices: { visible: false },
        fixed: true,
        highlight: false,
        visible: () => this.values.section === "6"
      });

      const holeCenter = bR.create("point", [() => cX(), () => cY()], { visible: false, fixed: true, highlight: false });
      const holeRadPt = bR.create("point", [() => cX() + Math.min(Td(), Math.min(Ld(), Hd()) * 0.45), () => cY()], {
        visible: false,
        fixed: true,
        highlight: false
      });
      const hole7 = bR.create("circle", [holeCenter, holeRadPt], {
        strokeColor: bgColor,
        fillColor: bgColor,
        fillOpacity: 1,
        fixed: true,
        highlight: false,
        visible: () => this.values.section === "7"
      });

      const ringCenter = bR.create("point", [() => cX(), () => cY()], { visible: false, fixed: true, highlight: false });
      const outerRadPt = bR.create("point", [() => cX() + Math.min(Ld(), Hd()) / 2, () => cY()], { visible: false, fixed: true, highlight: false });
      const innerRadPt = bR.create("point", [() => cX() + Math.min(Td(), Math.min(Ld(), Hd()) * 0.45), () => cY()], {
        visible: false,
        fixed: true,
        highlight: false
      });
      const outerRing = bR.create("circle", [ringCenter, outerRadPt], {
        strokeColor: "#7878df",
        fillColor: "#7878df",
        fillOpacity: 0.95,
        fixed: true,
        highlight: false,
        visible: () => this.values.section === "8"
      });
      const innerRing = bR.create("circle", [ringCenter, innerRadPt], {
        strokeColor: bgColor,
        fillColor: bgColor,
        fillOpacity: 1,
        fixed: true,
        highlight: false,
        visible: () => this.values.section === "8"
      });

      const origin = bR.create("point", [
        () => axisBaseX + sliderValue("newX") * axisScale,
        () => axisBaseY + sliderValue("newY") * axisScale
      ], {
        visible: false,
        fixed: true,
        highlight: false
      });

      const xTip = bR.create("point", [
        () => origin.X() + axisLenX,
        () => origin.Y()
      ], {
        visible: false,
        fixed: true,
        highlight: false
      });

      const yTip = bR.create("point", [
        () => origin.X(),
        () => origin.Y() + axisLenY
      ], {
        visible: false,
        fixed: true,
        highlight: false
      });

      const xAxis = bR.create("arrow", [origin, xTip], {
        strokeColor: "red",
        fillColor: "red",
        strokeWidth: 2,
        fixed: true,
        highlight: false
      });

      const yAxis = bR.create("arrow", [origin, yTip], {
        strokeColor: "red",
        fillColor: "red",
        strokeWidth: 2,
        fixed: true,
        highlight: false
      });

      const labelO = bR.create("text", [
        () => origin.X() - 0.08,
        () => origin.Y() - 0.02,
        "o"
      ], {
        fixed: true,
        fontSize: 18,
        strokeColor: "red"
      });

      const labelX = bR.create("text", [
        () => xTip.X() + 0.02,
        () => xTip.Y() - 0.02,
        "x"
      ], {
        fixed: true,
        fontSize: 18,
        strokeColor: "red"
      });

      const labelY = bR.create("text", [
        () => yTip.X() - 0.03,
        () => yTip.Y() + 0.03,
        "y"
      ], {
        fixed: true,
        fontSize: 18,
        strokeColor: "red"
      });

      const hDimX = () => xL() - 0.10;
      const hBottom = bR.create("point", [() => hDimX(), () => yBase], { visible: false, fixed: true, highlight: false });
      const hTop = bR.create("point", [() => hDimX(), () => yTop()], { visible: false, fixed: true, highlight: false });
      const hDim = bR.create("segment", [hBottom, hTop], {
        firstArrow: true,
        lastArrow: true,
        strokeColor: "#333",
        strokeWidth: 2,
        fixed: true,
        highlight: false
      });

      const lDimY = () => (this.values.section === "1" ? yBase - 0.08 : yTop() + 0.08);
      const lLeft = bR.create("point", [() => xL(), () => lDimY()], { visible: false, fixed: true, highlight: false });
      const lRight = bR.create("point", [() => xR(), () => lDimY()], { visible: false, fixed: true, highlight: false });
      const lDim = bR.create("segment", [lLeft, lRight], {
        firstArrow: true,
        lastArrow: true,
        strokeColor: "#333",
        strokeWidth: 2,
        fixed: true,
        highlight: false
      });

      const tHorizontalY = () => (this.values.section === "1" ? yBase + Td() + 0.05 : yMid() - 0.05);
      const tLeft = bR.create("point", [() => xWebR(), () => tHorizontalY()], { visible: false, fixed: true, highlight: false });
      const tRight = bR.create("point", [() => xR(), () => tHorizontalY()], { visible: false, fixed: true, highlight: false });
      const tDimH = bR.create("segment", [tLeft, tRight], {
        firstArrow: true,
        lastArrow: true,
        strokeColor: "#333",
        strokeWidth: 2,
        fixed: true,
        highlight: false,
        visible: () => this.values.section !== "4"
      });

      const tVerticalX = () => xC + Ld() * 0.25;
      const tVTop = bR.create("point", [() => tVerticalX(), () => yBase], { visible: false, fixed: true, highlight: false });
      const tVBottom = bR.create("point", [() => tVerticalX(), () => yBotInset()], { visible: false, fixed: true, highlight: false });
      const tDimV = bR.create("segment", [tVTop, tVBottom], {
        firstArrow: true,
        lastArrow: true,
        strokeColor: "#333",
        strokeWidth: 2,
        fixed: true,
        highlight: false,
        visible: () => this.values.section === "4"
      });

      const extL1 = bR.create("segment", [p[0], lLeft], { dash: 2, strokeColor: "#555", fixed: true, highlight: false });
      const extL2 = bR.create("segment", [p[1], lRight], { dash: 2, strokeColor: "#555", fixed: true, highlight: false });
      const extH1 = bR.create("segment", [bR.create("point", [() => xL(), () => yBase], { visible: false, fixed: true, highlight: false }), hBottom], {
        dash: 2,
        strokeColor: "#555",
        fixed: true,
        highlight: false
      });
      const extH2 = bR.create("segment", [bR.create("point", [() => xL(), () => yTop()], { visible: false, fixed: true, highlight: false }), hTop], {
        dash: 2,
        strokeColor: "#555",
        fixed: true,
        highlight: false
      });

      const lengthLabel = bR.create("text", [
        () => xC - 0.03,
        () => (this.values.section === "1" ? lDimY() - 0.10 : lDimY() + 0.08),
        () => this.fmtNum(sliderValue("length"))
      ], {
        fontSize: 24,
        fixed: true,
        strokeColor: "#333"
      });

      const heightLabel = bR.create("text", [() => hDimX() - 0.15, () => yBase + Hd() / 2, () => this.fmtNum(sliderValue("height"))], {
        fontSize: 24,
        fixed: true,
        strokeColor: "#333"
      });

      const thickLabel = bR.create("text", [
        () => (this.values.section === "4" ? tVerticalX() + 0.08 : (xWebR() + xR()) / 2 - 0.02),
        () => (this.values.section === "4" ? yBase + Td() / 2 : tHorizontalY() + 0.08),
        () => this.fmtNum(sliderValue("thickness"))
      ], {
        fontSize: 24,
        fixed: true,
        strokeColor: "#333"
      });

      this.rightObjects = {
        section,
        rectVoid,
        hole7,
        outerRing,
        innerRing,
        origin,
        xTip,
        yTip,
        xAxis,
        yAxis,
        labelO,
        labelX,
        labelY,
        hDim,
        lDim,
        tDimH,
        tDimV,
        extL1,
        extL2,
        extH1,
        extH2,
        lengthLabel,
        heightLabel,
        thickLabel
      };
    }
  }
};
</script>

